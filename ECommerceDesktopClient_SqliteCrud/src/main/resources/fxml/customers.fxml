<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.ecommerce.controllers.CustomersController"
      spacing="14" styleClass="page">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <children>
            <Label text="👤 Customers" styleClass="page-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchField" promptText="Search customers..." prefWidth="280"/>
            <Button text="Export CSV" onAction="#onExportCsv" styleClass="btn-secondary"/>
        </children>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS" styleClass="table">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="70"/>
            <TableColumn fx:id="colName" text="Name" prefWidth="200"/>
            <TableColumn fx:id="colEmail" text="Email" prefWidth="220"/>
            <TableColumn fx:id="colPhone" text="Phone" prefWidth="160"/>
            <TableColumn fx:id="colAddress" text="Address" prefWidth="260"/>
        </columns>
    </TableView>

    <VBox styleClass="card" spacing="10">
        <children>
            <Label text="Add / Update" styleClass="card-title"/>
            <HBox spacing="10">
                <children>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <children>
                            <Label text="Name" styleClass="field-label"/>
                            <TextField fx:id="nameField" promptText="Customer name"/>
                        </children>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <children>
                            <Label text="Email" styleClass="field-label"/>
                            <TextField fx:id="emailField" promptText="email@example.com"/>
                        </children>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <children>
                            <Label text="Phone" styleClass="field-label"/>
                            <TextField fx:id="phoneField" promptText="Phone number"/>
                        </children>
                    </VBox>
                </children>
            </HBox>

            <VBox spacing="6">
                <children>
                    <Label text="Address" styleClass="field-label"/>
                    <TextField fx:id="addressField" promptText="Street, City, Country"/>
                </children>
            </VBox>

            <HBox spacing="10">
                <children>
                    <Button fx:id="saveBtn" text="Add" onAction="#onSave" styleClass="btn-primary"/>
                    <Button fx:id="deleteBtn" text="Delete" onAction="#onDelete" styleClass="btn-danger"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Clear" onAction="#onClear" styleClass="btn-secondary"/>
                </children>
            </HBox>
        </children>
    </VBox>
</VBox>

