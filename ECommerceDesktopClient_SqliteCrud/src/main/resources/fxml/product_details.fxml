<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.ecommerce.controllers.ProductDetailsController"
      spacing="14" styleClass="page">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <Label text="Product details" styleClass="page-title"/>

    <VBox styleClass="card" spacing="12">
        <children>
            <GridPane hgap="12" vgap="10">
                <children>
                    <Label text="Name" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <Label fx:id="name" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Category" styleClass="field-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <Label fx:id="category" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Price" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <Label fx:id="price" text="-" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Stock" styleClass="field-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <Label fx:id="stock" text="-" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <Label text="Description" styleClass="field-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <Label fx:id="description" text="-" wrapText="true" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                    <Label text="Rating" styleClass="field-label" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                    <Label fx:id="rating" text="-" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                </children>
            </GridPane>

            <HBox spacing="10">
                <children>
                    <Label text="Add rating (1-5)" styleClass="field-label"/>
                    <Spinner fx:id="ratingSpinner" prefWidth="100"/>
                    <Button fx:id="rateBtn" text="Save rating" onAction="#onRate" styleClass="btn-primary"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </children>
            </HBox>
        </children>
    </VBox>
</VBox>

