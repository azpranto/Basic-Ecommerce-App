<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.ecommerce.controllers.OrdersController"
      spacing="14" styleClass="page">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <children>
            <Label text="📦 Orders" styleClass="page-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Export CSV" onAction="#onExportCsv" styleClass="btn-secondary"/>
            <Button text="Refresh" onAction="#onRefresh" styleClass="btn-secondary"/>
        </children>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS" styleClass="table">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="70"/>
            <TableColumn fx:id="colCustomer" text="Customer" prefWidth="200"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
            <TableColumn fx:id="colQuantity" text="Quantity" prefWidth="100"/>
            <TableColumn fx:id="colPayment" text="Payment" prefWidth="120"/>
            <TableColumn fx:id="colTotal" text="Total" prefWidth="100"/>
            <TableColumn fx:id="colCreated" text="Created" prefWidth="180"/>
        </columns>
    </TableView>

    <VBox styleClass="card" spacing="10">
        <children>
            <Label text="Order Actions" styleClass="card-title"/>
            <HBox spacing="10">
                <children>
                    <Label text="Status" styleClass="field-label"/>
                    <ChoiceBox fx:id="statusChoice"/>
                    <Button fx:id="updateStatusBtn" text="Update Status" onAction="#onUpdateStatus" styleClass="btn-primary"/>
                    <Button fx:id="deleteBtn" text="Delete Order" onAction="#onDeleteOrder" styleClass="btn-danger"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="statusHint" text="" styleClass="muted"/>
                </children>
            </HBox>
        </children>
    </VBox>
</VBox>

